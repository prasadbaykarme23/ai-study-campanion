# AI Study Companion Backend Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# FIREBASE ADMIN SDK CONFIGURATION
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Generate a strong random string for JWT_SECRET
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_32_chars_min

# JWT Token Expiration
JWT_EXPIRE=7d

# ============================================
# AI PROVIDER CONFIGURATION
# ============================================
# Choose ONE of the following AI providers:

# Option 1: Groq API (Recommended - Faster inference, lower cost)
# Get your API key from: https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=gsk-your-groq-api-key-here

# Option 2: OpenAI API (Legacy fallback)
# Get your API key from: https://platform.openai.com/api-keys
# Model used: gpt-3.5-turbo
# If not provided, the app will use mock quiz generator as fallback
OPENAI_API_KEY=sk-your-openai-api-key-here

# Note: If both keys are present, Groq will be used preferentially
# Groq provides faster inference and often better quality results

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port where the backend server runs
PORT=5000

# Environment (development, production, test)
NODE_ENV=development

# ============================================
# CLIENT CONFIGURATION (CORS)
# ============================================
# URL where frontend is hosted (for CORS)
CLIENT_URL=http://localhost:3000

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file size for uploads (in bytes)
# Default: 10MB (10485760 bytes)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=uploads

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================
# SESSION CONFIGURATION
# ============================================
# Session timeout in milliseconds (default: 24 hours)
SESSION_TIMEOUT=86400000

# ============================================
# OPTIONAL: DATABASE BACKUP
# ============================================
# For automated backups (optional)
# BACKUP_ENABLED=false
# BACKUP_INTERVAL=daily

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================
# For password reset emails (future feature)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@aistudy.com
